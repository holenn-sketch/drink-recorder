page {
  min-height: 100%;
  color: #3a2415;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  background:
    radial-gradient(circle at 16% 8%, rgba(255, 248, 231, 0.74), transparent 28%),
    radial-gradient(circle at 86% 18%, rgba(214, 166, 79, 0.22), transparent 34%),
    linear-gradient(118deg, rgba(122, 75, 42, 0.12), transparent 34%),
    repeating-linear-gradient(96deg, rgba(122, 75, 42, 0.11) 0rpx, rgba(122, 75, 42, 0.11) 4rpx, transparent 4rpx, transparent 38rpx),
    linear-gradient(145deg, #f1e3c6 0%, #e8d3a8 58%, #d9b77d 100%);
}

view,
text,
button,
input {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  line-height: 1.2;
  background: transparent;
}

button::after {
  border: 0;
}
